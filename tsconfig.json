{
    "compilerOptions": {
        "lib": ["ESNext", "DOM"],
        "types": ["node"],
        "skipLibCheck": true,
        "module": "ESNext",
        "moduleResolution": "node",
        "target": "ESNext",
        "isolatedModules": true,
        "esModuleInterop": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "outDir": "dist",
        "resolveJsonModule": true,
        "moduleDetection": "force"
    },
    "exclude": ["node_modules"],
    "include": ["src/**/*.ts", "bin/*.ts"]
}
